      objectReference: {fileID: 0}
    - target: {fileID: 1317100978998197740, guid: 97e88e93d0be8446ca55570b8de282a4, type: 3}
      propertyPath: dialogueLines.Array.data[3].speaker
      value: Cave
      objectReference: {fileID: 0}
    - target: {fileID: 1317100978998197740, guid: 97e88e93d0be8446ca55570b8de282a4, type: 3}
      propertyPath: dialogueLines.Array.data[4].speaker
      value: You
      objectReference: {fileID: 0}
    - target: {fileID: 1317100978998197740, guid: 97e88e93d0be8446ca55570b8de282a4, type: 3}
      propertyPath: dialogueLines.Array.data[5].speaker
      value: Cave
      objectReference: {fileID: 0}
    - target: {fileID: 1317100978998197740, guid: 97e88e93d0be8446ca55570b8de282a4, type: 3}
      propertyPath: dialogueLines.Array.data[6].speaker
      value: You
      objectReference: {fileID: 0}
    - target: {fileID: 1317100978998197740, guid: 97e88e93d0be8446ca55570b8de282a4, type: 3}
      propertyPath: dialogueLines.Array.data[7].speaker
      value: You
      objectReference: {fileID: 0}
    - target: {fileID: 1317100978998197740, guid: 97e88e93d0be8446ca55570b8de282a4, type: 3}
      propertyPath: dialogueLines.Array.data[8].speaker
      value: Cave
      objectReference: {fileID: 0}
    - target: {fileID: 1317100978998197740, guid: 97e88e93d0be8446ca55570b8de282a4, type: 3}
      propertyPath: dialogueLines.Array.data[9].speaker
      value: Cave
      objectReference: {fileID: 0}
    - target: {fileID: 1317100978998197740, guid: 97e88e93d0be8446ca55570b8de282a4, type: 3}
      propertyPath: dialogueLines.Array.data[0].dialogue
      value: You made it.
      objectReference: {fileID: 0}
    - target: {fileID: 1317100978998197740, guid: 97e88e93d0be8446ca55570b8de282a4, type: 3}
      propertyPath: dialogueLines.Array.data[10].speaker
      value: You
      objectReference: {fileID: 0}
    - target: {fileID: 1317100978998197740, guid: 97e88e93d0be8446ca55570b8de282a4, type: 3}
      propertyPath: dialogueLines.Array.data[11].speaker
      value: Cave
      objectReference: {fileID: 0}
    - target: {fileID: 1317100978998197740, guid: 97e88e93d0be8446ca55570b8de282a4, type: 3}
      propertyPath: dialogueLines.Array.data[1].dialogue
      value: Thought I'd fail?
      objectReference: {fileID: 0}
    - target: {fileID: 1317100978998197740, guid: 97e88e93d0be8446ca55570b8de282a4, type: 3}
      propertyPath: dialogueLines.Array.data[2].dialogue
      value: I don't think. I wait. I've only ever waited.
      objectReference: {fileID: 0}
    - target: {fileID: 1317100978998197740, guid: 97e88e93d0be8446ca55570b8de282a4, type: 3}
      propertyPath: dialogueLines.Array.data[3].dialogue
      value: 'Most don''t make it here. They only merge with the walls. '
      objectReference: {fileID: 0}
    - target: {fileID: 1317100978998197740, guid: 97e88e93d0be8446ca55570b8de282a4, type: 3}
      propertyPath: dialogueLines.Array.data[4].dialogue
      value: That won't be me.
      objectReference: {fileID: 0}
    - target: {fileID: 1317100978998197740, guid: 97e88e93d0be8446ca55570b8de282a4, type: 3}
      propertyPath: dialogueLines.Array.data[5].dialogue
      value: You all say it.
      objectReference: {fileID: 0}
    - target: {fileID: 1317100978998197740, guid: 97e88e93d0be8446ca55570b8de282a4, type: 3}
      propertyPath: dialogueLines.Array.data[6].dialogue
      value: And yet here I am.
      objectReference: {fileID: 0}
    - target: {fileID: 1317100978998197740, guid: 97e88e93d0be8446ca55570b8de282a4, type: 3}
      propertyPath: dialogueLines.Array.data[7].dialogue
      value: What's further down?
      objectReference: {fileID: 0}
    - target: {fileID: 1317100978998197740, guid: 97e88e93d0be8446ca55570b8de282a4, type: 3}
      propertyPath: dialogueLines.Array.data[8].dialogue
      value: 'All the things. Parts of me sitting still for eons. '
      objectReference: {fileID: 0}
    - target: {fileID: 1317100978998197740, guid: 97e88e93d0be8446ca55570b8de282a4, type: 3}
      propertyPath: dialogueLines.Array.data[9].dialogue
      value: 'I wonder how they''ll greet you. '
      objectReference: {fileID: 0}
    - target: {fileID: 1317100978998197740, guid: 97e88e93d0be8446ca55570b8de282a4, type: 3}
      propertyPath: dialogueLines.Array.data[10].dialogue
      value: Warmly, I hope.
      objectReference: {fileID: 0}
    - target: {fileID: 1317100978998197740, guid: 97e88e93d0be8446ca55570b8de282a4, type: 3}
      propertyPath: dialogueLines.Array.data[11].dialogue
      value: No. Not warmly. It's cold down there. Cold.
      objectReference: {fileID: 0}
    - target: {fileID: 1317100978998197740, guid: 97e88e93d0be8446ca55570b8de282a4, type: 3}
