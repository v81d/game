      propertyPath: dialogueLines.Array.data[0].hint
      value: Jump and give in to your curiosity, or don't.
      objectReference: {fileID: 0}
    - target: {fileID: 1317100978998197740, guid: 97e88e93d0be8446ca55570b8de282a4, type: 3}
      propertyPath: dialogueLines.Array.data[1].hint
