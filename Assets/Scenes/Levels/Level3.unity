    - target: {fileID: 1317100978998197740, guid: 97e88e93d0be8446ca55570b8de282a4, type: 3}
      propertyPath: dialogueLines.Array.data[0].dialogue
      value: Oh . . .
      objectReference: {fileID: 0}
    - target: {fileID: 1317100978998197740, guid: 97e88e93d0be8446ca55570b8de282a4, type: 3}
      propertyPath: dialogueLines.Array.data[10].speaker
      value: You
      objectReference: {fileID: 0}
    - target: {fileID: 1317100978998197740, guid: 97e88e93d0be8446ca55570b8de282a4, type: 3}
      propertyPath: dialogueLines.Array.data[11].speaker
      value: Air
      objectReference: {fileID: 0}
    - target: {fileID: 1317100978998197740, guid: 97e88e93d0be8446ca55570b8de282a4, type: 3}
      propertyPath: dialogueLines.Array.data[12].speaker
      value: Cave
      objectReference: {fileID: 0}
    - target: {fileID: 1317100978998197740, guid: 97e88e93d0be8446ca55570b8de282a4, type: 3}
      propertyPath: dialogueLines.Array.data[13].speaker
      value: Air
      objectReference: {fileID: 0}
    - target: {fileID: 1317100978998197740, guid: 97e88e93d0be8446ca55570b8de282a4, type: 3}
      propertyPath: dialogueLines.Array.data[1].dialogue
      value: . . . oh my!
      objectReference: {fileID: 0}
    - target: {fileID: 1317100978998197740, guid: 97e88e93d0be8446ca55570b8de282a4, type: 3}
      propertyPath: dialogueLines.Array.data[2].dialogue
      value: Who's there?
      objectReference: {fileID: 0}
    - target: {fileID: 1317100978998197740, guid: 97e88e93d0be8446ca55570b8de282a4, type: 3}
      propertyPath: dialogueLines.Array.data[3].dialogue
      value: It has been so long. So extraordinarily long.
      objectReference: {fileID: 0}
    - target: {fileID: 1317100978998197740, guid: 97e88e93d0be8446ca55570b8de282a4, type: 3}
      propertyPath: dialogueLines.Array.data[4].dialogue
      value: What has?
      objectReference: {fileID: 0}
    - target: {fileID: 1317100978998197740, guid: 97e88e93d0be8446ca55570b8de282a4, type: 3}
      propertyPath: dialogueLines.Array.data[5].dialogue
      value: Since anything wet has fell so deep.
      objectReference: {fileID: 0}
    - target: {fileID: 1317100978998197740, guid: 97e88e93d0be8446ca55570b8de282a4, type: 3}
      propertyPath: dialogueLines.Array.data[6].dialogue
      value: This part of the cave . . . it dried out before the rest. Long before
        what happened up there.
      objectReference: {fileID: 0}
    - target: {fileID: 1317100978998197740, guid: 97e88e93d0be8446ca55570b8de282a4, type: 3}
      propertyPath: dialogueLines.Array.data[7].dialogue
      value: Don't mind it. It has been talking to itself for centuries.
      objectReference: {fileID: 0}
    - target: {fileID: 1317100978998197740, guid: 97e88e93d0be8446ca55570b8de282a4, type: 3}
      propertyPath: dialogueLines.Array.data[8].dialogue
      value: Hush, stone. Let me have this.
      objectReference: {fileID: 0}
    - target: {fileID: 1317100978998197740, guid: 97e88e93d0be8446ca55570b8de282a4, type: 3}
      propertyPath: dialogueLines.Array.data[9].dialogue
      value: Keep your guard up, little water. This place is not meant for things
        that flow.
      objectReference: {fileID: 0}
    - target: {fileID: 1317100978998197740, guid: 97e88e93d0be8446ca55570b8de282a4, type: 3}
      propertyPath: dialogueLines.Array.data[10].dialogue
      value: You sound like you know this place well.
      objectReference: {fileID: 0}
    - target: {fileID: 1317100978998197740, guid: 97e88e93d0be8446ca55570b8de282a4, type: 3}
      propertyPath: dialogueLines.Array.data[11].dialogue
      value: 'I am interlaced with it. I slip between all the cracks. Deeper than
        the cave itself. '
      objectReference: {fileID: 0}
    - target: {fileID: 1317100978998197740, guid: 97e88e93d0be8446ca55570b8de282a4, type: 3}
      propertyPath: dialogueLines.Array.data[12].dialogue
      value: Not true.
      objectReference: {fileID: 0}
    - target: {fileID: 1317100978998197740, guid: 97e88e93d0be8446ca55570b8de282a4, type: 3}
      propertyPath: dialogueLines.Array.data[13].dialogue
      value: You should go now, water.
      objectReference: {fileID: 0}
    - target: {fileID: 1317100978998197740, guid: 97e88e93d0be8446ca55570b8de282a4, type: 3}
      propertyPath: dialogueLines.Array.data[2].jumpAllowed
